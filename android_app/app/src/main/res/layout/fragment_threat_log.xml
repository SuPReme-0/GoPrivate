<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <com.goprivate.app.ui.views.GlitchTextView
                android:id="@+id/threat_log_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=">_ /var/log/quarantine.sys"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/alert_red_primary"
                android:fontFamily="monospace"
                android:letterSpacing="0.05"
                app:glitchEnabled="true"
                app:glitchIntensity="high"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/engine_stats_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:weightSum="3"
                app:layout_constraintTop_toBottomOf="@id/threat_log_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NETWORK_IDS"
                        android:textSize="9sp"
                        android:textColor="@color/terminal_text_dim"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/engine_a_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="14"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/neon_cyan_primary"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAYLOAD_SCANS"
                        android:textSize="9sp"
                        android:textColor="@color/terminal_text_dim"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/engine_b_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="3"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/alert_red_primary"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRIVACY_AUDITS"
                        android:textSize="9sp"
                        android:textColor="@color/terminal_text_dim"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/engine_c_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="8"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFAA00"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/filter_scroll_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/engine_stats_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/filter_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filter_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALL_LOGS"
                        android:checked="true"
                        android:textColor="@color/terminal_text_primary"
                        android:fontFamily="monospace"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/cyber_card_glass" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filter_malicious"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MALICIOUS"
                        android:textColor="@color/alert_red_primary"
                        android:fontFamily="monospace"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/cyber_card_glass"
                        app:chipStrokeColor="@color/alert_red_primary"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filter_suspicious"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUSPICIOUS"
                        android:textColor="#FFAA00"
                        android:fontFamily="monospace"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/cyber_card_glass"
                        app:chipStrokeColor="#FFAA00"
                        app:chipStrokeWidth="1dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/filter_safe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SAFE"
                        android:textColor="@color/neon_cyan_primary"
                        android:fontFamily="monospace"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/cyber_card_glass"
                        app:chipStrokeColor="@color/neon_cyan_primary"
                        app:chipStrokeWidth="1dp"/>

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <com.goprivate.app.ui.views.HolographicCard
                android:id="@+id/card_engine_a"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:hologramIntensity="1"
                app:glowColor="@color/neon_cyan_primary"
                app:cardBackgroundColor="#0A0A0A"
                app:strokeColor="@color/neon_cyan_primary"
                app:strokeWidth="1dp"
                app:cardCornerRadius="6dp"
                app:layout_constraintTop_toBottomOf="@id/filter_scroll_view"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=">_ [ENG_A] NETWORK_TRAFFIC"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/neon_cyan_primary"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:background="#1A00FFFF" />

                    <TextView
                        android:id="@+id/empty_state_engine_a"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:text="[ NO_NETWORK_LOGS ]"
                        android:textSize="12sp"
                        android:textColor="@color/terminal_text_dim"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_engine_a"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:nestedScrollingEnabled="false"
                        android:padding="8dp" />
                </LinearLayout>
            </com.goprivate.app.ui.views.HolographicCard>

            <com.goprivate.app.ui.views.HolographicCard
                android:id="@+id/card_engine_b"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:hologramIntensity="1"
                app:glowColor="@color/alert_red_primary"
                app:cardBackgroundColor="#0A0A0A"
                app:strokeColor="@color/alert_red_primary"
                app:strokeWidth="1dp"
                app:cardCornerRadius="6dp"
                app:layout_constraintTop_toBottomOf="@id/card_engine_a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=">_ [ENG_B] SYSTEM_VANGUARD"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/alert_red_primary"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:background="#1AFF0000" />

                    <TextView
                        android:id="@+id/empty_state_engine_b"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:text="[ NO_PAYLOAD_LOGS ]"
                        android:textSize="12sp"
                        android:textColor="@color/terminal_text_dim"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_engine_b"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:nestedScrollingEnabled="false"
                        android:padding="8dp" />
                </LinearLayout>
            </com.goprivate.app.ui.views.HolographicCard>

            <com.goprivate.app.ui.views.HolographicCard
                android:id="@+id/card_engine_c"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:hologramIntensity="1"
                app:glowColor="#FFAA00"
                app:cardBackgroundColor="#0A0A0A"
                app:strokeColor="#FFAA00"
                app:strokeWidth="1dp"
                app:cardCornerRadius="6dp"
                app:layout_constraintTop_toBottomOf="@id/card_engine_b"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=">_ [ENG_C] NLP_SENTINEL"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFAA00"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:background="#1AFFAA00" />

                    <TextView
                        android:id="@+id/empty_state_engine_c"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:text="[ NO_POLICY_LOGS ]"
                        android:textSize="12sp"
                        android:textColor="@color/terminal_text_dim"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_engine_c"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:nestedScrollingEnabled="false"
                        android:padding="8dp" />
                </LinearLayout>
            </com.goprivate.app.ui.views.HolographicCard>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_clear_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="Purge Quarantine Logs"
        app:backgroundTint="#0A0A0A"
        app:tint="@color/alert_red_primary"
        app:borderWidth="2dp"
        app:rippleColor="@color/alert_red_primary"
        app:elevation="8dp" />

    <com.goprivate.app.ui.views.HolographicCard
        android:id="@+id/forensicDetailsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:visibility="gone"
        android:elevation="24dp"
        android:translationZ="24dp"
        android:clickable="true"
        android:focusable="true"
        app:hologramIntensity="3"
        app:glowColor="@color/neon_cyan_glow"
        app:cardBackgroundColor="#E6050505"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/neon_cyan_primary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ FORENSIC DECRYPTION ]"
                android:textSize="10sp"
                android:textColor="@color/terminal_text_dim"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/threatNameDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/terminal_text_primary"
                android:fontFamily="monospace"
                tools:text="Telegram FOSS" />

            <TextView
                android:id="@+id/threatTargetDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/terminal_text_secondary"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp"
                tools:text="org.telegram.messenger" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/threatEngineDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:textColor="@color/neon_cyan_primary"
                tools:text="[ ENGINE B : XAI_STATIC ]" />

            <TextView
                android:id="@+id/threatSeverityDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                tools:textColor="@color/alert_red_primary"
                tools:text="> SEVERITY: CRITICAL PAYLOAD" />

            <TextView
                android:id="@+id/threatScoreDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                tools:textColor="@color/alert_red_primary"
                tools:text="AI_CONFIDENCE: 92%" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="16dp"
                android:background="#121212"
                android:padding="8dp">

                <TextView
                    android:id="@+id/threatVectorLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/terminal_text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    tools:text="> Raw Action Log..." />
            </ScrollView>

            <TextView
                android:id="@+id/threatTimeDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/terminal_text_dim"
                android:fontFamily="monospace"
                android:gravity="end"
                android:layout_marginTop="12dp"
                tools:text="Logged: Oct 24, 2026 - 14:32" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap anywhere to dismiss"
                android:textSize="9sp"
                android:textColor="@color/terminal_text_dim"
                android:textStyle="italic"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </com.goprivate.app.ui.views.HolographicCard>

</androidx.coordinatorlayout.widget.CoordinatorLayout>