<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/settings_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:text="[ SYSTEM_CONFIGURATION ]"
            android:textColor="@color/neon_purple_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/settings_subheader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="Manage Core AI Engines and Firewall strictness."
            android:textColor="@color/terminal_text_dim"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/settings_header" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/engine_config_card"
            style="@style/Widget.GoPrivate.CyberCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/cyber_card_glass"
            app:cardCornerRadius="8dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/settings_subheader">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="monospace"
                    android:text="NEURAL ENGINES"
                    android:textColor="@color/neon_purple_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/file_access_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Engine B: Static Payload Scan"
                    android:textColor="@color/terminal_text_primary"
                    android:textStyle="bold"
                    app:thumbTint="@color/neon_purple_primary"
                    app:trackTint="@color/cyber_card_glass" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="monospace"
                    android:text="Grant access to statically inspect downloaded APKs and file payloads for known hostile signatures."
                    android:textColor="@color/terminal_text_secondary"
                    android:textSize="11sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/auditor_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Engine C: Autonomous Auditor"
                    android:textColor="@color/terminal_text_primary"
                    android:textStyle="bold"
                    app:thumbTint="@color/neon_purple_primary"
                    app:trackTint="@color/cyber_card_glass" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="[ REQUIRES_ACCESSIBILITY ] Monitor Chrome URLs automatically and silently scrape/audit privacy policies in the background."
                    android:textColor="@color/terminal_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/network_config_card"
            style="@style/Widget.GoPrivate.CyberCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cyber_card_glass"
            app:cardCornerRadius="8dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/engine_config_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="monospace"
                    android:text="NETWORK SUBSYSTEM"
                    android:textColor="@color/neon_purple_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/vpn_mode_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Autonomous VPN Ignition"
                    android:textColor="@color/terminal_text_primary"
                    android:textStyle="bold"
                    app:thumbTint="@color/neon_purple_primary"
                    app:trackTint="@color/cyber_card_glass" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="monospace"
                    android:text="Dynamically establish secure tunnels on app launch. Disabling this switches the system to Manual Mode."
                    android:textColor="@color/terminal_text_secondary"
                    android:textSize="11sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/notifications_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Real-Time Threat Alerts"
                    android:textColor="@color/terminal_text_primary"
                    android:textStyle="bold"
                    app:thumbTint="@color/neon_purple_primary"
                    app:trackTint="@color/cyber_card_glass" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Allow Engine A to fire instant OS heads-up notifications when a C2 Beacon or malware is intercepted."
                    android:textColor="@color/terminal_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/privacy_card"
            style="@style/Widget.GoPrivate.CyberCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cyber_card_glass"
            app:cardCornerRadius="8dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/network_config_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="monospace"
                    android:text="GLOBAL THREAT INTELLIGENCE"
                    android:textColor="@color/neon_purple_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/telemetry_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Anonymous Telemetry"
                    android:textColor="@color/terminal_text_primary"
                    android:textStyle="bold"
                    app:thumbTint="@color/neon_purple_primary"
                    app:trackTint="@color/cyber_card_glass" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="[ SECURE_PIPELINE ] Share completely anonymous inference speeds and blocked malware hashes to improve the global ML models. Zero personal IP data is transmitted."
                    android:textColor="@color/terminal_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/danger_zone_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#0A0A0A"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/alert_red_primary"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/privacy_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="monospace"
                    android:text="DANGER ZONE"
                    android:textColor="@color/alert_red_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clear_history_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="PURGE THREAT LOGS"
                    android:textColor="@color/cyber_bg_deep"
                    android:textStyle="bold"
                    app:backgroundTint="@color/alert_red_primary"
                    app:cornerRadius="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/app_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:text="GoPrivate OS v1.0.0-rc1"
            android:textColor="@color/terminal_text_dim"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/danger_zone_card" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>