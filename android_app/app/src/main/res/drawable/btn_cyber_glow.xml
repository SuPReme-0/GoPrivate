<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ✅ Pressed + Enabled -->
    <item android:state_pressed="true" android:state_enabled="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/neon_cyan_glow" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neon_cyan_primary" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- ✅ Focused + Enabled -->
    <item android:state_focused="true" android:state_enabled="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/neon_cyan_glow" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neon_cyan_primary" />
                    <corners android:radius="11dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- ✅ Disabled -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyber_card_glass" />
            <stroke
                android:width="1dp"
                android:color="@color/terminal_text_dim" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- ✅ Default (Normal/Enabled) -->
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/cyber_card_glass" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/neon_cyan_primary" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="45"
                        android:startColor="#2000F5FF"
                        android:endColor="#00000000"
                        android:type="linear" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
