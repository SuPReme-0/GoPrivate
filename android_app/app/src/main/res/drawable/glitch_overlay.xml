<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Subtle glitch scan lines using gradient -->
    <gradient
        android:angle="90"
        android:startColor="#00FFFFFF"
        android:centerColor="#1000F5FF"
        android:endColor="#00FFFFFF"
        android:type="linear" />

    <!-- Optional: Add a stroke for border effect -->
    <stroke
        android:width="0.5dp"
        android:color="#0A00F5FF" />

</shape>